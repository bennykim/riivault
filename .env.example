# --- DB (docker-compose 기본값) ---
DATABASE_URL=postgresql://riivault:riivault@localhost:5433/riivault

# --- Reddit API (비상업 무료 tier, https://www.reddit.com/prefs/apps) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=macos:riivault:v0.1 (non-commercial research; by /u/YOUR_USERNAME)
REDDIT_QPM=90

# --- Hacker News (no key required — Algolia public API) ---
HN_ENABLED=true
HN_RPM=60
HN_HITS_PER_PAGE=50
HN_MAX_PAGES_PER_TERM=2

# --- 수집 대상 (쉼표 구분, 미설정 시 SaaS 니치 기본셋) ---
RIIVAULT_SUBREDDITS=SaaS,Entrepreneur,startups,indiehackers,webdev,nocode,microsaas,SideProject,EntrepreneurRideAlong,smallbusiness

# --- AI (선택: 없으면 VoC 추출 단계 skip, 감성은 VADER) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Web ---
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
